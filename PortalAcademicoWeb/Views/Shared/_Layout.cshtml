Aquí está el _Layout.cshtml completo con todos los cambios:
Views/Shared/_Layout.cshtml
html<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portal Académico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🎓 Portal Académico
                </a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- Links principales -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Home"
                               asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Cursos"
                               asp-action="Index">Catálogo</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Matriculas"
                                   asp-action="MisMatriculas">Mis Matrículas</a>
                            </li>
                        }
                        @if (User.IsInRole("Coordinador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning"
                                   asp-controller="Coordinador"
                                   asp-action="Index">⚙ Coordinador</a>
                            </li>
                        }
                    </ul>

                    <!-- Último curso visitado (sesión Redis P4) -->
                    @{
                        var ultimoId = Context.Session.GetString("UltimoCursoId");
                        var ultimoNombre = Context.Session.GetString("UltimoCursoNombre");
                    }
                    @if (!string.IsNullOrEmpty(ultimoId))
                    {
                        <ul class="navbar-nav me-3">
                            <li class="nav-item">
                                <a class="nav-link text-info"
                                   asp-controller="Cursos"
                                   asp-action="Detalle"
                                   asp-route-id="@ultimoId">
                                    ↩ Volver a: @ultimoNombre
                                </a>
                            </li>
                        </ul>
                    }

                    <!-- Menú de usuario -->
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white-50">
                                    👤 @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="/Identity/Account/Logout">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="/" />
                                    <button type="submit"
                                            class="btn btn-link nav-link text-danger">
                                        Cerrar sesión
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   href="/Identity/Account/Login">Iniciar sesión</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   href="/Identity/Account/Register">Registrarse</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">

        <!-- Mensajes globales -->
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Exito"]
                <button type="button" class="btn-close"
                        data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close"
                        data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 - Portal Académico Universidad
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>